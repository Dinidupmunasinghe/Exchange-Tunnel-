# Dev with HTTPS (recommended for Meta): use `/api` (Vite proxies to backend). Plain http:// dev: `http://localhost:5000/api`
VITE_API_BASE_URL=/api
# App used for /login (Facebook Login use case)
VITE_META_LOGIN_APP_ID=
# App used for /settings page-connect flow (Pages use case)
VITE_META_PAGES_APP_ID=
