NODE_ENV=development
PORT=5000

DB_HOST=localhost
DB_PORT=3306
DB_NAME=facebook_exchange
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_SYNC_ALTER=false

JWT_SECRET=replace_with_long_secure_secret
JWT_EXPIRES_IN=7d

ENCRYPTION_SECRET=replace_with_32_char_secret_key____

# App used by /auth/facebook login flow
META_LOGIN_APP_ID=your_login_meta_app_id
META_LOGIN_APP_SECRET=your_login_meta_app_secret
# App used by /facebook/connect page flow
META_PAGES_APP_ID=your_pages_meta_app_id
META_PAGES_APP_SECRET=your_pages_meta_app_secret
META_GRAPH_API_BASE=https://graph.facebook.com/v22.0

CORS_ORIGIN=http://localhost:5173

DAILY_EARN_LIMIT=500
LIKE_REWARD=5
COMMENT_REWARD=10
SHARE_REWARD=15
